 <Window x:Class="HardwareManager.view.EditRequestWin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
            xmlns:local="clr-namespace:HardwareManager.view"
            xmlns:vm="clr-namespace:HardwareManager.viewModel"
            xmlns:mm="clr-namespace:HardwareManager.model"
            xmlns:conv="clr-namespace:HardwareManager.infrastructure.utils.converters"
        mc:Ignorable="d"
        Title="EditRequestWin" SizeToContent="WidthAndHeight" WindowStartupLocation="CenterScreen" ResizeMode="CanMinimize">
    <Window.DataContext>
        <vm:EditRequestVM/>
    </Window.DataContext>
    <Window.Resources>
        <ResourceDictionary Source="/view/resources/MyResources.xaml"/>
    </Window.Resources>
    <Grid x:Name="WindowMainContainer" Height="250" Width="600" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Button Grid.Row="3" Style="{StaticResource ButtonPrimary}" Content="Сохранить" Command="{Binding Path=SaveCommand}" HorizontalAlignment="Left"  Width="200"/>
        <Button Grid.Row="3" Style="{StaticResource ButtonPrimary}" Content="Выйти" Command="{Binding Path=ExitCommand}" HorizontalAlignment="Right" Width="200"/>

        <DockPanel Grid.Row="0" VerticalAlignment="Top">
            <TextBlock Text="{Binding Path=RequestHeaderText, StringFormat='\{0\}:'}" DockPanel.Dock="Top" FontSize="30" FontFamily="Segoe UI Black" TextWrapping="Wrap" Foreground="#FF131373"/>
            <Border DockPanel.Dock="Top" BorderBrush="#FF131373" BorderThickness="1" Padding="10,10" CornerRadius="5" Margin="0,10">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,10">
                        <TextBlock Text="Причина запроса:  " Style="{StaticResource TextBlockMediumStyle}" HorizontalAlignment="Left"/>
                        <ComboBox x:Name="ReasonNameTB" SelectedValue="{Binding Path=RequestView.ReasonName}" ItemsSource="{x:Static mm:StaticCatalogs.RequestReasonNameCatalog}" Style="{StaticResource ComboBoxMediumStyle}" Width="250" HorizontalAlignment="Left"/>
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Тип оборудования:  " Style="{StaticResource TextBlockMediumStyle}" HorizontalAlignment="Left"/>
                        <ComboBox  x:Name="RequestedTypeNameTB" SelectedValue="{Binding Path=RequestView.RequestedTypeName}" ItemsSource="{x:Static mm:StaticCatalogs.AllHardwareNamesCatalog}" Style="{StaticResource ComboBoxMediumStyle}" Width="300" HorizontalAlignment="Left"/>
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Инвентарный номер:  " Style="{StaticResource TextBlockMediumStyle}" HorizontalAlignment="Left"/>
                        <ComboBox SelectedValue="{Binding Path=RequestView.HardwareIN}" ItemsSource="{Binding Path=WorkPlaceHardwareINs}" Style="{StaticResource ComboBoxMediumStyle}" Width="150" HorizontalAlignment="Left"/>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ElementName=ReasonNameTB, Path=SelectedValue}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ElementName=ReasonNameTB, Path=SelectedValue}" Value="Необходимо оборудование">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ElementName=RequestedTypeNameTB, Path=SelectedValue}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ElementName=RequestedTypeNameTB, Path=SelectedValue}" Value="Кабель">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ElementName=RequestedTypeNameTB, Path=SelectedValue}" Value="Адаптер">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                    </StackPanel>
                </DockPanel>
            </Border>
        </DockPanel>
    </Grid>
</Window>
