<Window x:Class="HardwareManager.view.LoginWin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
            xmlns:local="clr-namespace:HardwareManager.view"
            xmlns:vm="clr-namespace:HardwareManager.viewModel"
        mc:Ignorable="d"
        Title="LoginWin" WindowStartupLocation="CenterScreen" SizeToContent="WidthAndHeight" ResizeMode="CanMinimize">
    <Window.DataContext>
        <vm:LoginVM/>
    </Window.DataContext>
    <Window.Resources>
        <ResourceDictionary Source="/view/resources/MyResources.xaml"/>
    </Window.Resources>
    <Grid x:Name="WindowMainContainer" Height="550" Width="900">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.4*"/>
            <ColumnDefinition/>
            <ColumnDefinition Width="0.4*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <!--<RowDefinition Height="0.1*"/>-->
            <RowDefinition/>
            <RowDefinition Height="0.1*"/>
        </Grid.RowDefinitions>

        <UniformGrid Grid.Row="0" Grid.ColumnSpan="3" Margin="00,20">
            <Border>
                <Border.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="White"/>
                        <GradientStop Color="#FF87D1EA" Offset="0.05"/>
                        <GradientStop Color="White" Offset="1"/>
                        <GradientStop Color="#FF87D1EA" Offset="0.95"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid VerticalAlignment="Center" Margin="0,12">
                    <Grid.Background>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0" SpreadMethod="Pad">
                            <LinearGradientBrush.RelativeTransform>
                                <TransformGroup>
                                    <ScaleTransform CenterY="0.5" CenterX="0.5"/>
                                    <SkewTransform CenterX="0.5" CenterY="0.5"/>
                                    <RotateTransform Angle="90" CenterX="0.5" CenterY="0.5"/>
                                    <TranslateTransform/>
                                </TransformGroup>
                            </LinearGradientBrush.RelativeTransform>
                            <GradientStop Color="#FF424EFF" Offset="0.25"/>
                            <GradientStop Color="#FF87D1EA" Offset="0.8"/>
                            <GradientStop Color="#FF87D1EA" Offset="0.2"/>
                            <GradientStop Color="#FF424EFF" Offset="0.75"/>
                        </LinearGradientBrush>
                    </Grid.Background>
                    <TextBlock Text="АВТОРИЗАЦИЯ" VerticalAlignment="Center" HorizontalAlignment="Stretch" TextAlignment="Center" FontSize="30" FontFamily="Segoe UI Black" Foreground="White" Visibility="{Binding Path=LoginHeaderPanelVisibility}"/>
                    <TextBlock Text="РЕГИСТРАЦИЯ" VerticalAlignment="Center" HorizontalAlignment="Stretch" TextAlignment="Center" FontSize="30" FontFamily="Segoe UI Black" Foreground="White" Visibility="{Binding Path=LoginHeaderPanelVisibility, Converter={StaticResource ReverseValueConverter}}"/>
                </Grid>
            </Border>
        </UniformGrid>
        
        <UniformGrid Grid.Column="1" Grid.Row="1" Columns="1" Rows="1">
            <Border Visibility="{Binding Path=LoginFormVisibility}" BorderBrush="LightBlue" BorderThickness="3" CornerRadius="25" Padding="35,20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="0.7*"/>
                        <RowDefinition Height="0.5*"/>
                        <RowDefinition Height="0.3*"/>
                        <RowDefinition Height="0.3*"/>
                        <RowDefinition Height="0.5*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Имя пользователя: " FontFamily="Microsoft YaHei" FontSize="18" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" FontFamily="Calibri" MaxLength="50" FontSize="18" Text="{Binding Path=AccountView.Username}" VerticalAlignment="Center" HorizontalAlignment="Stretch" Padding="3"/>
                        <TextBlock Grid.Row="1" Text="Пароль: " FontFamily="Microsoft YaHei" FontSize="18" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="1" Grid.Column="1" FontFamily="Calibri" MaxLength="20" FontSize="18" Text="{Binding Path=AccountView.Password}" VerticalAlignment="Center" HorizontalAlignment="Stretch" Padding="3"/>
                    </Grid>
                    <DockPanel VerticalAlignment="Center" Grid.Row="1" Name="DP_NEED_TO_HIDE_AND_SHOW" Visibility="{Binding Path=LoginErrorPanelVisibility}">
                            <Image Width="25" Margin="0,0,5,0" Height="25" Source="/infrastructure/utils/database/AnimatedLoadingImg.png" RenderOptions.BitmapScalingMode="HighQuality"/>
                            <TextBlock FontSize="16" FontFamily="Franklin Gothic Medium" TextWrapping="Wrap">
                                    Учетной записи с такими данными не существует. Желаете <Hyperlink Command="{Binding Path=GoToRegistrationFormCommand}">создать</Hyperlink> ее?
                            </TextBlock>
                        </DockPanel>

                    <Button Style="{DynamicResource ButtonPrimary}" Grid.Row="2" VerticalAlignment="Top" Content="Войти" Command="{Binding Path=LoginCommand}" Height="38"/>
                    <Button Style="{DynamicResource ButtonPrimary}" Grid.Row="3" VerticalAlignment="Top" Content="Регистрация" Command="{Binding Path=GoToRegistrationFormCommand}"/>
                    <Button Style="{DynamicResource ButtonPrimary}" Grid.Row="4" VerticalAlignment="Center" Content="Выход" Command="{Binding Path=ExitCommand}"/>
                </Grid>
            </Border>

            
            <Border Visibility="{Binding Path=RegistrationFormVisibility}" BorderBrush="LightBlue" BorderThickness="3" CornerRadius="25" Padding="35,20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="0.1*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="0.5*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition MinWidth="100" Width="0.75*"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Имя пользователя: " Grid.Row="1" Grid.Column="0" FontFamily="Microsoft YaHei" FontSize="18" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Grid.Row="1" MaxLength="50" FontFamily="Calibri" FontSize="20" Text="{Binding Path=AccountView.Username}" HorizontalAlignment="Stretch" VerticalAlignment="Center" Padding="3"/>
                    <TextBlock Grid.Row="2" Text="Пароль: " FontFamily="Microsoft YaHei" FontSize="18" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="2" Grid.Column="1" MaxLength="20" Margin="0,10" FontFamily="Calibri" FontSize="20" Text="{Binding Path=AccountView.Password}" HorizontalAlignment="Stretch" VerticalAlignment="Top" Padding="3"/>
                    <TextBlock Grid.Row="3" Text="Повторите пароль: " FontFamily="Microsoft YaHei" FontSize="18" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="3" Grid.Column="1" MaxLength="20" FontFamily="Calibri" FontSize="20" Text="{Binding Path=AccountView.RepeatedPassword}" HorizontalAlignment="Stretch" VerticalAlignment="Top" Padding="3"/>
                    
                    <TextBlock Grid.Row="4" Text="Кабинет: " Margin="0,20,0,0" FontFamily="Microsoft YaHei" FontSize="18" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <ComboBox Grid.Row="4" Grid.Column="1" FontFamily="Calibri" Margin="0,20,0,0" FontSize="20" SelectedValue="{Binding Path=CabinetNameCBSelectedValue}" ItemsSource="{Binding Path=CabinetsNames}" HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Padding="3"/>
                    <TextBlock Grid.Row="5" Text="Рабочее место: " Margin="0,10,0,0" FontFamily="Microsoft YaHei" FontSize="18" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <ComboBox Grid.Row="5" Grid.Column="1" FontFamily="Calibri" Margin="0,10,0,0" FontSize="20" SelectedValue="{Binding Path=AccountView.Workplace}" ItemsSource="{Binding Path=WorkplacesNames}" HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Padding="3"/>

                    <!--<StackPanel Grid.Row="0" Grid.ColumnSpan="2">
                        <Grid Margin="10,25,10,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition MinWidth="100" Width="0.3*"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                        </Grid>
                        <DockPanel Margin="10" Visibility="{Binding Path=LoginErrorPanelVisibility}">
                            <Image Width="25" Height="25" Margin="5,0" Source="/infrastructure/utils/database/AnimatedLoadingImg.png" RenderOptions.BitmapScalingMode="HighQuality"/>
                            <TextBlock FontSize="16" FontFamily="Franklin Gothic Medium" TextWrapping="Wrap">
                                    Учетной записи с такими данными не существует. Желаете <Hyperlink Command="{Binding Path=RegistrationCommand}">создать</Hyperlink> ее?
                            </TextBlock>
                        </DockPanel>
                    </StackPanel>-->

                    <Button Style="{DynamicResource ButtonPrimary}" Grid.Row="6" Grid.ColumnSpan="2" VerticalAlignment="Center" Content="Зарегистрироваться" Command="{Binding Path=RegistrationCommand}"/>
                    <Button Style="{DynamicResource ButtonPrimary}" Grid.Row="7" Grid.ColumnSpan="2" VerticalAlignment="Center" Content="Отмена" Command="{Binding Path=CancelRegistrationCommand}"/>
                </Grid>
            </Border>

            <Border Visibility="{Binding Path=SuccessFormVisibility}" BorderBrush="LightBlue" BorderThickness="3" CornerRadius="25" Padding="35,20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="0.2*"/>
                        <RowDefinition Height="0.8*"/>
                        <RowDefinition Height="0.5*"/>
                        <RowDefinition Height="0.4*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition MinWidth="100" Width="0.75*"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <TextBlock FontSize="22" Grid.Row="1" Grid.ColumnSpan="2" FontFamily="Franklin Gothic Medium" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center">
                                    Пользователь с именем «<Run Text="{Binding Path=AccountView.Username}"></Run>» успешно зарегистрирован. Вы модете продолжить работу с программой как данный пользователь, либо вернуться к окну авторизации.
                    </TextBlock>


                    <Button Style="{DynamicResource ButtonPrimary}" Grid.Row="2" Grid.ColumnSpan="2" VerticalAlignment="Center" Content="Продолжить работу" Command="{Binding Path=LoginCommand}"/>
                    <Button Style="{DynamicResource ButtonPrimary}" Grid.Row="3" Grid.ColumnSpan="2" VerticalAlignment="Center" Content="К окну авторизации" Command="{Binding Path=GoToLoginFormCommand}"/>
                </Grid>
            </Border>

        </UniformGrid>
    </Grid>
</Window>
