 <Window x:Class="HardwareManager.view.UserViewWorkplaceWin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
            xmlns:local="clr-namespace:HardwareManager.view"
            xmlns:vm="clr-namespace:HardwareManager.viewModel"
            xmlns:conv="clr-namespace:HardwareManager.infrastructure.utils.converters"
        mc:Ignorable="d"
        Title="UserViewWorkplaceWin" SizeToContent="WidthAndHeight" WindowStartupLocation="CenterScreen" ResizeMode="CanMinimize">
    <Window.DataContext>
        <vm:UserViewWorkplaceVM/>
    </Window.DataContext>
    <Window.Resources>
        <ResourceDictionary Source="/view/resources/MyResources.xaml"/>
    </Window.Resources>
    <Grid x:Name="WindowMainContainer" Height="550" Width="900">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <UniformGrid Grid.Row="0" Margin="0,10">
            <Border>
                <Border.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="White"/>
                        <GradientStop Color="#FF87D1EA" Offset="0.05"/>
                        <GradientStop Color="White" Offset="1"/>
                        <GradientStop Color="#FF87D1EA" Offset="0.95"/>
                    </LinearGradientBrush>
                </Border.Background>
                <DockPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10" Background="#FF424EFF">
                    <Border Width="50">
                        <Border.Background>
                            <LinearGradientBrush EndPoint="1,1" StartPoint="0,1">
                                <GradientStop Color="#FF424EFF" Offset="0.5"/>
                                <GradientStop Color="#FF87D1EA" Offset="0.018"/>
                                <GradientStop Color="#FF424EFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <TextBlock Text="{Binding Path=WorkPlaceView.Name, StringFormat='Рабочее место: {0}'}" VerticalAlignment="Center" HorizontalAlignment="Stretch" TextAlignment="Center" FontSize="30" FontFamily="Segoe UI Black" Foreground="White"/>
                    <Rectangle Width="50">
                        <Rectangle.Fill>
                            <LinearGradientBrush EndPoint="1,1" StartPoint="0,1">
                                <GradientStop Color="#FF424EFF" Offset="0.5"/>
                                <GradientStop Color="#FF87D1EA" Offset="0.99"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                </DockPanel>
            </Border>
        </UniformGrid>

        <Image Grid.Row="1" Source="/resources/images/fon_workplace.png" RenderOptions.BitmapScalingMode="Fant" Stretch="Fill" Panel.ZIndex="0"/>

        <TabControl Grid.Row="1" Panel.ZIndex="10" Height="350" Margin="20">
            <TabItem Header="Оборудование" IsSelected="True" Foreground="#FF131373" FontSize="16" FontFamily="Arial Black">
                <ListBox DockPanel.Dock="Top" ItemContainerStyle="{StaticResource UnselectableListBoxItemStyle}" ItemsSource="{Binding Path=WorkPlaceView.HardwareList}" VerticalAlignment="Stretch" Background="#E5FFFFFF" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Visible">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Width="{Binding RelativeSource={RelativeSource AncestorType=ListBox}, Path=ActualWidth}"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Width="410" BorderBrush="Gray" BorderThickness="1" Padding="5">
                                <DockPanel>
                                    <DockPanel DockPanel.Dock="Top">
                                        <Border Height="100" Width="100" HorizontalAlignment="Left" Margin="0,0,5,0" BorderBrush="Black" BorderThickness="1" VerticalAlignment="Top">
                                            <Grid>
                                                <Image RenderOptions.BitmapScalingMode="HighQuality" Stretch="Fill" Source="/resources/images/noImageForHardware.png"/>
                                                <Image Source="{Binding Path=HardwareImage, Converter={conv:BytesToImageConverter}}" RenderOptions.BitmapScalingMode="HighQuality" Stretch="Fill"/>
                                            </Grid>
                                        </Border>
                                        <TextBlock DockPanel.Dock="Top" Text="{Binding Path=HardwareName}" VerticalAlignment="Top" Style="{StaticResource TextBlockMediumStyle}"/>
                                        <TextBlock DockPanel.Dock="Top" Text="{Binding Path=Model}" Margin="0,5" VerticalAlignment="Top" Style="{StaticResource TextBlockMediumInformalStyle}"/>
                                        <DockPanel DockPanel.Dock="Top" VerticalAlignment="Top">
                                            <TextBlock Text="Инв. номер: " Width="100" HorizontalAlignment="Left" Style="{StaticResource TextBlockMediumStyle}"/>
                                            <TextBlock Text="{Binding Path=InventorialNumber}" Style="{StaticResource TextBlockMediumInformalStyle}"/>
                                        </DockPanel>
                                        <DockPanel DockPanel.Dock="Top" VerticalAlignment="Top" Margin="0,5,0,0">
                                            <TextBlock Text="Статус:  " HorizontalAlignment="Left" Style="{StaticResource TextBlockMediumStyle}"/>
                                            <TextBlock Text="{Binding Path=InventorialStatus}" Style="{StaticResource TextBlockMediumInformalStyle}"/>
                                            <Button Content="Обзор" Width="75" HorizontalAlignment="Right" DataContext="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Window}, Path=DataContext}" Command="{Binding Path=ViewHardwareCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=ListBoxItem}, Path=Content}" Style="{StaticResource ButtonSecondarySmall}"/>
                                        </DockPanel>
                                    </DockPanel>
                                </DockPanel>
                            </Border>

                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </TabItem>
            <TabItem Header="Провода, кабели" IsSelected="True" Foreground="#FF131373" FontSize="16" FontFamily="Arial Black">
                <ListBox DockPanel.Dock="Top" ItemContainerStyle="{StaticResource UnselectableListBoxItemStyle}" ItemsSource="{Binding Path=WorkPlaceView.WireList}" VerticalAlignment="Stretch" Background="#E5FFFFFF" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Visible">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Width="{Binding RelativeSource={RelativeSource AncestorType=ListBox}, Path=ActualWidth}"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Width="410" BorderBrush="Gray" BorderThickness="1" Padding="5">
                                <DockPanel>
                                    <DockPanel DockPanel.Dock="Top">
                                        <Border Height="100" Width="100" HorizontalAlignment="Left" Margin="0,0,5,0" BorderBrush="Black" BorderThickness="1" VerticalAlignment="Top">
                                            <Grid>
                                                <Image RenderOptions.BitmapScalingMode="HighQuality" Stretch="Fill" Source="/resources/images/noImageForHardware.png"/>
                                                <Image Source="{Binding Path=HardwareImage, Converter={conv:BytesToImageConverter}}" RenderOptions.BitmapScalingMode="HighQuality" Stretch="Fill"/>
                                            </Grid>
                                        </Border>
                                        <TextBlock DockPanel.Dock="Top" Text="{Binding Path=WireName}" VerticalAlignment="Top" Style="{StaticResource TextBlockMediumStyle}"/>
                                        <TextBlock DockPanel.Dock="Top" Text="{Binding Path=Model}" Margin="0,5" VerticalAlignment="Top" Style="{StaticResource TextBlockMediumInformalStyle}"/>
                                        <DockPanel DockPanel.Dock="Top" VerticalAlignment="Top">
                                            <TextBlock Text="Количество: " HorizontalAlignment="Left" Style="{StaticResource TextBlockMediumStyle}"/>
                                            <TextBlock Text="{Binding Path=ItemCount, StringFormat='\{0\} шт.'}" Style="{StaticResource TextBlockMediumInformalStyle}"/>
                                        </DockPanel>
                                        <DockPanel DockPanel.Dock="Top" VerticalAlignment="Top" Margin="0,5,0,0">
                                            <Button Content="Обзор" Width="75" HorizontalAlignment="Right" DataContext="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Window}, Path=DataContext}" Command="{Binding Path=ViewHardwareCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=ListBoxItem}, Path=Content}" Style="{StaticResource ButtonSecondarySmall}"/>
                                        </DockPanel>
                                    </DockPanel>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </TabItem>
        </TabControl>

        <DockPanel Grid.Row="2">
            <Button Style="{DynamicResource ButtonPrimary}" Margin="20" Width="250" HorizontalAlignment="Left" Content="Выход" Command="{Binding Path=ExitCommand}"/>
            <Button Style="{DynamicResource ButtonPrimary}" Width="250" HorizontalAlignment="Left" Content="Выход из аккаунта" Command="{Binding Path=ExitAccountCommand}"/>
            <Button Style="{DynamicResource ButtonPrimary}" Margin="20" Width="250" HorizontalAlignment="Right" Content="Запросы" Command="{Binding Path=MailCommand}"/>
        </DockPanel>
    </Grid>
</Window>
