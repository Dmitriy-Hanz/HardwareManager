 <Window x:Class="HardwareManager.view.AdminMailWin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
            xmlns:local="clr-namespace:HardwareManager.view"
            xmlns:vm="clr-namespace:HardwareManager.viewModel"
        mc:Ignorable="d"
        Title="AdminMailWin" SizeToContent="WidthAndHeight" WindowStartupLocation="CenterScreen" ResizeMode="CanMinimize">
    <Window.DataContext>
        <vm:AdminMailVM/>
    </Window.DataContext>
    <Window.Resources>
        <ResourceDictionary Source="/view/resources/MyResources.xaml"/>
    </Window.Resources>
    <Grid x:Name="WindowMainContainer" Height="500" Width="800">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <UniformGrid Grid.Row="0" Margin="0,10">
            <Border>
                <Border.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="White"/>
                        <GradientStop Color="#FF87D1EA" Offset="0.05"/>
                        <GradientStop Color="White" Offset="1"/>
                        <GradientStop Color="#FF87D1EA" Offset="0.95"/>
                    </LinearGradientBrush>
                </Border.Background>
                <DockPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10" Background="#FF424EFF">
                    <Border Width="50">
                        <Border.Background>
                            <LinearGradientBrush EndPoint="1,1" StartPoint="0,1">
                                <GradientStop Color="#FF424EFF" Offset="0.5"/>
                                <GradientStop Color="#FF87D1EA" Offset="0.018"/>
                                <GradientStop Color="#FF424EFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <TextBlock Text="Почта" VerticalAlignment="Center" HorizontalAlignment="Stretch" TextAlignment="Center" FontSize="30" FontFamily="Segoe UI Black" Foreground="White"/>
                    <Rectangle Width="50">
                        <Rectangle.Fill>
                            <LinearGradientBrush EndPoint="1,1" StartPoint="0,1">
                                <GradientStop Color="#FF424EFF" Offset="0.5"/>
                                <GradientStop Color="#FF87D1EA" Offset="0.99"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                </DockPanel>
            </Border>
        </UniformGrid>

        <ListBox Grid.Row="1" Margin="20" DockPanel.Dock="Top" ItemContainerStyle="{StaticResource UnselectableListBoxItemStyle}" ItemsSource="{Binding Path=Requests}" VerticalAlignment="Stretch" HorizontalContentAlignment="Stretch" Background="#E5FFFFFF" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Visible">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Gray" BorderThickness="1" Padding="5" HorizontalAlignment="Stretch" MinHeight="50">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                                <Grid Tag="{Binding Path=Status}">
                                    <Button Content="Отклонить" Width="150" DataContext="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Window}, Path=DataContext}" Command="{Binding Path=DenyRequestCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=ListBoxItem}, Path=Content}" Style="{StaticResource ButtonSecondarySmall}"/>
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Style.Triggers>
                                                <Trigger Property="Tag" Value="Отменено">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </Trigger>
                                                <Trigger Property="Tag" Value="Одобрено">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                </Grid>
                                <Grid Tag="{Binding Path=Status}" Margin="0,5">
                                    <Button Content="Одобрить" Width="150" DataContext="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Window}, Path=DataContext}" Command="{Binding Path=ApplyRequestCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=ListBoxItem}, Path=Content}" Style="{StaticResource ButtonSecondarySmall}"/>
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Style.Triggers>
                                                <Trigger Property="Tag" Value="Отменено">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </Trigger>
                                                <Trigger Property="Tag" Value="Одобрено">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                </Grid>
                                <Grid Tag="{Binding Path=Status}" DockPanel.Dock="Right" HorizontalAlignment="Right">
                                    <Button Content="Удалить" Width="150" DataContext="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Window}, Path=DataContext}" Command="{Binding Path=DeleteRequestCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=ListBoxItem}, Path=Content}" Style="{StaticResource ButtonSecondarySmall}"/>
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Style.Triggers>
                                                <Trigger Property="Tag" Value="В обработке">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                </Grid>
                            </StackPanel>

                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Рабочее место:   " Style="{StaticResource TextBlockMediumStyle}"/>
                                    <TextBlock Text="{Binding Path=OwnerWorkPlaceName}" Style="{StaticResource TextBlockMediumInformalStyle}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,5">
                                    <TextBlock Text="{Binding Path=ReasonName, StringFormat='\{0\}:   '}" Style="{StaticResource TextBlockMediumStyle}"/>
                                    <TextBlock Text="{Binding Path=RequestedTypeName}" Style="{StaticResource TextBlockMediumInformalStyle}"/>
                                </StackPanel>
                                <DockPanel>
                                    <StackPanel Tag="{Binding Path=HardwareIN}" Orientation="Horizontal">
                                        <TextBlock Text="Инв. номер: " Width="100" HorizontalAlignment="Left" Style="{StaticResource TextBlockMediumStyle}"/>
                                        <TextBlock Text="{Binding Path=HardwareIN}" Style="{StaticResource TextBlockMediumInformalStyle}"/>
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Style.Triggers>
                                                    <Trigger Property="Tag" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                    </StackPanel>
                                    <StackPanel DockPanel.Dock="Right" VerticalAlignment="Bottom" HorizontalAlignment="Right" Orientation="Horizontal" Margin="5,0,30,0">
                                        <TextBlock Text="Статус:  " Style="{StaticResource TextBlockMediumStyle}"/>
                                        <TextBlock Text="{Binding Path=Status}" Style="{StaticResource TextBlockMediumInformalStyle}"/>
                                    </StackPanel>
                                </DockPanel>
                            </StackPanel>

                        </DockPanel>
                    </Border>

                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <DockPanel Grid.Row="2">
            <Button Style="{DynamicResource ButtonPrimary}" Margin="20" Width="250" HorizontalAlignment="Left" Content="Выход" Command="{Binding Path=ExitCommand}"/>
        </DockPanel>
    </Grid>
</Window>
