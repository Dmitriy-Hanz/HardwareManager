<Window x:Class="HardwareManager.view.HistoryWin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
            xmlns:local="clr-namespace:HardwareManager.view"
            xmlns:vm="clr-namespace:HardwareManager.viewModel"
            xmlns:mm="clr-namespace:HardwareManager.model"
            xmlns:conv="clr-namespace:HardwareManager.infrastructure.utils.converters"
        mc:Ignorable="d"
        Title="HistoryWin" SizeToContent="WidthAndHeight" WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:HistoryVM/>
    </Window.DataContext>
    <Window.Resources>
        <ResourceDictionary Source="/view/resources/MyResources.xaml"/>
    </Window.Resources>
    <Grid x:Name="WindowMainContainer" Width="800" Height="400" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ListView DockPanel.Dock="Top" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" FontSize="14" ItemsSource="{Binding Path=HistoryRecords}" ScrollViewer.VerticalScrollBarVisibility="Visible" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListView.View>
                <GridView>
                    <GridViewColumn DisplayMemberBinding="{Binding Path=OperationDateStr}" Header="Дата"/>
                    <GridViewColumn DisplayMemberBinding="{Binding Path=OperationType}" Header="Событие"/>
                    <GridViewColumn DisplayMemberBinding="{Binding Path=HardwareType}" Header="Тип оборудования"/>
                    <GridViewColumn DisplayMemberBinding="{Binding Path=InventorialNumber}" Header="Инвентарный номер"/>
                    <GridViewColumn DisplayMemberBinding="{Binding Path=WorkplaceName}" Header="Рабочее место"/>
                </GridView>
            </ListView.View>
        </ListView>

        <Expander Grid.Row="1" Grid.ColumnSpan="2" Header="Поиск" FontFamily="Tahoma" FontSize="20" FontWeight="Bold" Foreground="#FF131373" BorderBrush="Gray" ExpandDirection="Up" Style="{StaticResource ExpanderStyle1Vertical}" Margin="0,10,0,20" IsExpanded="False">
            <DockPanel Margin="10">
                <StackPanel DockPanel.Dock="Bottom"  Orientation="Horizontal">
                    <Button Content="Поиск" Width="120" Margin="0,0,10,0" Style="{StaticResource ButtonSecondary}" Command="{Binding Path=SearchCommand}"/>
                    <Button Content="Очистить фильтры" Width="220" Style="{StaticResource ButtonSecondary}" Command="{Binding Path=ClearFiltersCommand}"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Top" VerticalAlignment="Top" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,0,0,5">
                    <TextBlock Text="Дата:  " Style="{StaticResource TextBlockMediumStyle}" HorizontalAlignment="Left"/>
                    <DatePicker Width="150" SelectedDate="{Binding Path=SearchDate}" FontSize="15" Margin="0,0,20,0"/>
                    <TextBlock Text="Событие:  " Style="{StaticResource TextBlockMediumStyle}" HorizontalAlignment="Left"/>
                    <ComboBox Width="150" SelectedValue="{Binding Path=SearchOperation}" ItemsSource="{x:Static mm:StaticCatalogs.HistoryOperationCatalog}" Style="{StaticResource ComboBoxMediumStyle}"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Top" VerticalAlignment="Top"  Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,0,0,5">

                </StackPanel>
            </DockPanel>
        </Expander>

        <DockPanel Grid.Row="2" Grid.ColumnSpan="2">
            <Button Content="Выйти" HorizontalAlignment="Left" VerticalAlignment="Top" Width="138" Command="{Binding Path=CloseCommand}" Style="{StaticResource ButtonPrimary}"/>
            <Button Content="Отчистить журнал" HorizontalAlignment="Right" Width="250" Command="{Binding Path=ClearHistoryCommand}" Style="{StaticResource ButtonPrimary}"/>
        </DockPanel>
    </Grid>
</Window>
