 <Window x:Class="HardwareManager.view.SelectHardwareFromInventoryWin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
            xmlns:local="clr-namespace:HardwareManager.view"
            xmlns:vm="clr-namespace:HardwareManager.viewModel"
        mc:Ignorable="d"
        Title="SelectHardwareFromInventoryWin" SizeToContent="WidthAndHeight" WindowStartupLocation="CenterScreen" ResizeMode="CanMinimize">
    <Window.DataContext>
        <vm:SelectHardwareFromInventoryVM/>
    </Window.DataContext>
    <Window.Resources>
        <ResourceDictionary Source="/view/resources/MyResources.xaml"/>
    </Window.Resources>
    <Grid x:Name="WindowMainContainer" Height="500" Width="700">
        <Grid.RowDefinitions>
            <RowDefinition Height="4*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Grid.Column="0" Margin="10">
            <TextBlock Text="Инвентарь" DockPanel.Dock="Top" Style="{StaticResource TextBlockLargeStyle}"/>
            <Expander DockPanel.Dock="Bottom" Header="Поиск" FontFamily="Tahoma" FontSize="20" FontWeight="Bold" Foreground="#FF131373" BorderBrush="Gray" ExpandDirection="Up" Style="{StaticResource ExpanderStyle1Vertical}" Margin="0,5,0,0">
                <DockPanel Height="100">

                </DockPanel>
            </Expander>
            <TabControl SelectedIndex="{Binding Path=TabSelectedIndex}" DockPanel.Dock="Top" Margin="0,5,0,0" FontFamily="Microsoft YaHei" FontWeight="Bold">
                <TabItem Header="Оборудование" IsSelected="True" Foreground="#FF131373">
                    <ListBox ItemsSource="{Binding Path=MainHardwareList}" SelectedIndex="0" SelectedItem="{Binding Path=SelectedHardware}" HorizontalContentAlignment="Stretch" Padding="0,3" BorderThickness="1" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Visible">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderThickness="1" BorderBrush="Black" Padding="5">
                                    <DockPanel>
                                        <Image Width="50" Height="50" Margin="0,0,10,0" VerticalAlignment="Top" Tag="{Binding Path=HardwareType}" RenderOptions.BitmapScalingMode="HighQuality" Style="{StaticResource HardwareSmallIconImageStyle}"/>
                                        <StackPanel HorizontalAlignment="Stretch">
                                            <TextBlock Text="{Binding Path=HardwareName}" Style="{StaticResource TextBlockMediumStyle}"/>
                                            <TextBlock Text="{Binding Path=Model}" Style="{StaticResource TextBlockMediumInformalStyle}" Margin="0,5,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Button Width="130" DockPanel.Dock="Right" HorizontalAlignment="Right" Margin="0,0,5,0" Content="Обзор" DataContext="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Window}, Path=DataContext}" Command="{Binding Path=ViewHardwareCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=ListBoxItem}, Path=Content}" Style="{StaticResource ButtonSecondarySmall}"/>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </TabItem>
                <TabItem Header="Провода, кабели" Foreground="#FF131373">
                    <ListBox ItemsSource="{Binding Path=WiresList}" SelectedItem="{Binding Path=SelectedWire}" HorizontalContentAlignment="Stretch" Padding="0,3" BorderThickness="1" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Visible">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderThickness="1" BorderBrush="Black" Padding="5">
                                    <DockPanel>
                                        <Image Width="53" Height="53" Margin="0,0,10,0" VerticalAlignment="Top" Tag="{Binding Path=WireType}" RenderOptions.BitmapScalingMode="HighQuality" Style="{StaticResource HardwareSmallIconImageStyle}"/>
                                        <Button Width="130" DockPanel.Dock="Right" HorizontalAlignment="Right" Margin="0,0,5,0" Content="Обзор" DataContext="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Window}, Path=DataContext}" Command="{Binding Path=ViewHardwareCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=ListBoxItem}, Path=Content}" Style="{StaticResource ButtonSecondarySmall}"/>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Path=WireName}" Style="{StaticResource TextBlockMediumStyle}" FontSize="16"/>
                                            <TextBlock Margin="0,5" DockPanel.Dock="Top" Text="{Binding Path=Model}" Style="{StaticResource TextBlockMediumInformalStyle}"/>
                                            <DockPanel DockPanel.Dock="Top" HorizontalAlignment="Stretch">
                                                <TextBlock Text="Количество: " Style="{StaticResource TextBlockMediumStyle}"/>
                                                <TextBlock Text="{Binding Path=ItemCount, StringFormat='\{0\} шт.'}" Style="{StaticResource TextBlockMediumInformalStyle}"/>
                                            </DockPanel>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </TabItem>
            </TabControl>
        </DockPanel>
        <Button Content="Отмена" Grid.Row="1" Style="{StaticResource ButtonPrimary}" Margin="10" Command="{Binding Path=CancelCommand}" Width="250" HorizontalAlignment="Left"/>
        <Button Content="Добавить" Grid.Row="1" Style="{StaticResource ButtonPrimary}" Margin="10" Command="{Binding Path=ApplyCommand}" Width="250" HorizontalAlignment="Right"/>
    </Grid>
</Window>
