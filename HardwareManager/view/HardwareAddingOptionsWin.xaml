 <Window x:Class="HardwareManager.view.HardwareAddingOptionsWin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
            xmlns:local="clr-namespace:HardwareManager.view"
            xmlns:vm="clr-namespace:HardwareManager.viewModel"
        mc:Ignorable="d"
        Title="Способ добавления" SizeToContent="WidthAndHeight" WindowStartupLocation="CenterScreen" ResizeMode="CanMinimize">
    <Window.DataContext>
        <vm:HardwareAddingOptionsVM/>
    </Window.DataContext>
    <Window.Resources>
        <ResourceDictionary Source="/view/resources/MyResources.xaml"/>
    </Window.Resources>
    <Grid x:Name="WindowMainContainer" Height="230" Width="350" Margin="20">
        <UniformGrid Rows="1" VerticalAlignment="Top">
            <Button Padding="5" Margin="10" Background="White" Command="{Binding Path=SelectCommand}" CommandParameter="CreateNew">
                <Button.Content>
                    <StackPanel>
                        <Border Padding="5" BorderBrush="Gray" BorderThickness="0">
                            <Image Width="100" Stretch="Fill" Source="/resources/images/Icon_create_new.png" RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Border>
                        <TextBlock Text="Создать новое" Style="{StaticResource TextBlockMediumStyle}" Margin="0,5" TextAlignment="Center"/>
                    </StackPanel>
                </Button.Content>
            </Button>
            <Button Padding="5" Margin="10" Background="White" Command="{Binding Path=SelectCommand}" CommandParameter="FromInventory">
                <Button.Content>
                    <StackPanel>
                        <Border Padding="5" BorderBrush="Gray" BorderThickness="0">
                            <Image Width="100" Stretch="Fill" Source="/resources/images/Icon_from_inventory.png" RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Border>
                        <TextBlock Text="Из инвентаря" Style="{StaticResource TextBlockMediumStyle}" Margin="0,5" TextAlignment="Center"/>
                    </StackPanel>
                </Button.Content>
            </Button>
        </UniformGrid>

        <Button Content="Отмена" Style="{StaticResource ButtonPrimary}" DockPanel.Dock="Bottom" VerticalAlignment="Bottom" Command="{Binding Path=CancelCommand}"/>
    </Grid>
</Window>
