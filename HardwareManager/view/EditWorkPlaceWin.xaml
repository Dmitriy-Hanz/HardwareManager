 <Window x:Class="HardwareManager.view.EditWorkPlaceWin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
            xmlns:local="clr-namespace:HardwareManager.view"
            xmlns:vm="clr-namespace:HardwareManager.viewModel"
        mc:Ignorable="d"
        Title="EditWorkPlaceWin" SizeToContent="WidthAndHeight" WindowStartupLocation="CenterScreen" ResizeMode="CanMinimize">
    <Window.DataContext>
        <vm:EditWorkPlaceVM/>
    </Window.DataContext>
    <Window.Resources>
        <ResourceDictionary Source="/view/resources/MyResources.xaml"/>
    </Window.Resources>
    <Grid x:Name="WindowMainContainer" Height="250" Width="650">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <UniformGrid Grid.Row="0" Margin="0,10">
            <Border>
                <Border.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="White"/>
                        <GradientStop Color="#FF87D1EA" Offset="0.05"/>
                        <GradientStop Color="White" Offset="1"/>
                        <GradientStop Color="#FF87D1EA" Offset="0.95"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid VerticalAlignment="Center" Margin="10">
                    <Grid.Background>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0" SpreadMethod="Pad">
                            <LinearGradientBrush.RelativeTransform>
                                <TransformGroup>
                                    <ScaleTransform CenterY="0.5" CenterX="0.5"/>
                                    <SkewTransform CenterX="0.5" CenterY="0.5"/>
                                    <RotateTransform Angle="90" CenterX="0.5" CenterY="0.5"/>
                                    <TranslateTransform/>
                                </TransformGroup>
                            </LinearGradientBrush.RelativeTransform>
                            <GradientStop Color="#FF424EFF" Offset="0.25"/>
                            <GradientStop Color="#FF87D1EA" Offset="0.8"/>
                            <GradientStop Color="#FF87D1EA" Offset="0.2"/>
                            <GradientStop Color="#FF424EFF" Offset="0.75"/>
                        </LinearGradientBrush>
                    </Grid.Background>
                    <TextBlock Text="Новое рабочее место" VerticalAlignment="Center" HorizontalAlignment="Stretch" TextAlignment="Center" FontSize="30" FontFamily="Segoe UI Black" Foreground="White" Visibility="{Binding Path=NewWorkPlaceViewElementsVisibility}"/>
                    <TextBlock Text="Рабочее место" VerticalAlignment="Center" HorizontalAlignment="Stretch" TextAlignment="Center" FontSize="30" FontFamily="Segoe UI Black" Foreground="White" Visibility="{Binding Path=NewWorkPlaceViewElementsVisibility, Converter={StaticResource ReverseValueConverter}}"/>
                </Grid>
            </Border>
        </UniformGrid>

        <StackPanel Margin="30,0" Grid.Row="1">
            <Separator Margin="0,10"/>
            <DockPanel Margin="10,10">
                <TextBlock Text="Название:" VerticalAlignment="Center" TextAlignment="Left" MinWidth="100" FontFamily="Arial Rounded MT Bold" FontSize="20"/>
                <TextBox Text="{Binding Path=WorkPlaceView.Name}" MaxLength="75" FontFamily="Bahnschrift Light" FontSize="20"/>
            </DockPanel>
            <Separator Margin="0,10"/>
        </StackPanel>

        <UniformGrid Margin="20,10" Rows="1" Grid.Row="2">
            <Button Content="Сохранить" Style="{StaticResource ButtonPrimary}" Visibility="{Binding Path=NewWorkPlaceViewElementsVisibility, Converter={StaticResource ResourceKey=ReverseValueConverter}}" Margin="0,0,3,0" Command="{Binding Path=SaveCommand}"/>
            <Button Content="Создать" Style="{StaticResource ButtonPrimary}" Visibility="{Binding Path=NewWorkPlaceViewElementsVisibility}" Margin="0,0,3,0" Command="{Binding Path=SaveCommand}"/>
            <Button Content="Отмена" Style="{StaticResource ButtonPrimary}" Margin="3,0,0,0" Command="{Binding Path=CancelCommand}"/>
        </UniformGrid>
    </Grid>
</Window>
